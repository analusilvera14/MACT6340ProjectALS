<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <title>Projects | Ana L. Silvera</title>
    <meta name="author" content="Ana L. Silvera">
    <meta name="description" content="A gallery of NFT projects.">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Montserrat:wght@300;400;500;600&family=Raleway:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
  </head>

  <body>
    <%- include('header') %>

    <section class="section-block py-5">
      <div class="container">

        <h2 class="section-title text-center mb-5">Projects</h2>

        <div class="row g-4">
          <% projectArray.forEach(p => { %>
            <div class="col-12 col-sm-6 col-lg-4 d-flex">
              <div class="project-card w-100 d-flex flex-column">

                <img src="<%= p.img_url %>"
                     class="card-img-top"
                     alt="An image of the <%= p.project_name %> project">

                <div class="card-body d-flex flex-column">
                  <h3 class="card-title"><%= p.project_name %></h3>

                  <p class="card-text flex-grow-1">
                    <%= p.project_description.length > 120
                        ? p.project_description.substring(0, 120) + '…'
                        : p.project_description %>
                  </p>

                  <a href="/project/<%= p.id %>"
                     class="btn-custom mt-3 text-decoration-none text-center align-self-start">
                    Project Profile
                  </a>
                </div>

              </div>
            </div>
          <% }) %>
        </div>

      </div>
    </section>

    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>