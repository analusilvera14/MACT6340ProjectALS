<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <!-- makes the page resize properly on phones and tablets -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="./images/favicon.ico">
    <title>Contact | Ana L. Silvera</title>
    <meta name="author" content="Ana L. Silvera">
    <meta name="description" content="A page to contact the artist.">

    <!-- bootstrap framework for layout, validation, and components -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- google fonts (montserrat, raleway, archivo black) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Montserrat:wght@400;500;600&family=Raleway:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- my custom styles -->
    <link rel="stylesheet" href="./css/style.css">
  </head>

  
  <body>


    <!-- header / navbar -->
    <nav class="navbar navbar-expand-lg fixed-top custom-navbar">
      <div class="container-fluid px-4">
        <a class="navbar-brand" href="/index">
          <img src="./images/favicon.ico" alt="Logo" width="32" height="32">
        </a>
        <!-- hamburger menu that shows on small screens -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item"><a class="nav-link" href="/index#featured">featured</a></li>
            <li class="nav-item"><a class="nav-link" href="/index#about">about</a></li>
            <li class="nav-item"><a class="nav-link" href="/projects">projects</a></li>
            <li class="nav-item"><a class="nav-link active" href="/contact">contact</a></li>
          </ul>
          <button class="btn btn-outline-light btn-wallet">connect wallet</button>
        </div>
      </div>
    </nav>

    
    <!-- contact form section -->
    <section class="section-block py-5">
      <div class="container">
        <h2 class="section-title text-center mb-5">get in touch</h2>

        <div class="row justify-content-center">
          <div class="col-md-8 col-lg-6">
            <form id="contact-form" class="needs-validation contact-form" novalidate>

              <!-- first name -->
              <div class="mb-3">
                <label for="contact-first" class="form-label">first name</label>
                <input type="text" id="contact-first" class="form-control" required>
                <div class="invalid-feedback">please enter your first name.</div>
              </div>

              <!-- middle name (optional) -->
              <div class="mb-3">
                <label for="contact-middle" class="form-label">middle name (optional)</label>
                <input type="text" id="contact-middle" class="form-control">
              </div>

              <!-- last name -->
              <div class="mb-3">
                <label for="contact-last" class="form-label">last name</label>
                <input type="text" id="contact-last" class="form-control" required>
                <div class="invalid-feedback">please enter your last name.</div>
              </div>

              <!-- email -->
              <div class="mb-3">
                <label for="contact-email-addr" class="form-label">email</label>
                <input type="email" id="contact-email-addr" class="form-control" required>
                <div class="invalid-feedback">please enter a valid email address.</div>
              </div>

              <!-- message -->
              <div class="mb-3">
                <label for="contact-question" class="form-label">your message</label>
                <textarea id="contact-question" class="form-control" rows="5" required></textarea>
                <div class="invalid-feedback">please write a message.</div>
              </div>

              <!-- submit button -->
              <div class="text-center">
                <button type="submit" id="send-contact" class="btn btn-custom">send message</button>
              </div>

              <!-- response area (filled in by contact.js after the server replies) -->
              <div id="contact-button-response" class="text-center mt-3"></div>

            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- footer -->
    <footer class="footer-section py-5">
      <div class="container">
        <div class="row align-items-center text-center text-md-start">
          <div class="col-md-8 mb-4 mb-md-0">
            
            <p class="mb-1">created by <strong>ana l. silvera</strong></p>
            <p class="mb-1">dallas, tx</p>
            <p class="mb-0 small">&copy; 2026 all rights reserved.</p>
          </div>
          <div class="col-md-4 text-md-end">
            <p class="mb-2">questions / comments</p>
            <a href="/contact" class="btn btn-custom">contact</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- bootstrap javascript (needed for navbar and form validation styling) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- my contact form logic -->
    <script type="module" src="./js/contact.js"></script>
  </body>
</html>